# Copy this file to `.env` for LOCAL testing. NEVER commit `.env`.
# In production these variables are set as GitHub Actions Secrets.
#
# You only need ONE email provider. Pick either Resend OR Gmail SMTP.
# Both are free. The script auto-selects whichever you've configured.

# --- Required ---
EMAIL_TO=vmgrosso02@yahoo.com          # where the brief is delivered
RECIPIENT_NAME=Michael                  # used in the greeting

# --- Option A: Resend (easiest — no app password, no 2FA dance) ---
# Sign up free at https://resend.com → API Keys → Create
# Free tier: 3,000 emails/month, 100/day. Sender: onboarding@resend.dev works immediately.
RESEND_API_KEY=re_...
EMAIL_FROM=Daily Brief <onboarding@resend.dev>

# --- Option B: Gmail SMTP (fully free, unlimited for personal use) ---
# Requires: 2-Step Verification enabled on your Google account,
# then create an App Password at https://myaccount.google.com/apppasswords
# GMAIL_USER=your.address@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char app password, spaces OK

# --- Optional ---
DRY_RUN=0                               # 1 = generate HTML but don't send email
